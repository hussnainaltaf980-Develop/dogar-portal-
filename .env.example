# ===========================================================================
#  Dogar OEP Portal — environment configuration
#  Copy this file to `.env` and fill in real values before deploying.
#    cp .env.example .env
# ===========================================================================

# ---- Runtime mode -----------------------------------------------------------
# development | staging | production
# In `production` the app HARD-FAILS at startup if any guardrail below is
# violated (weak secret, weak admin password, demo flags left on, etc.).
ENV=production

# ---- Security (REQUIRED in production) -------------------------------------
# Generate a strong key:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# JWT access-token lifetime in minutes (default 1440 = 24h)
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ---- Bootstrap admin (created on first launch) -----------------------------
# Must be a STRONG password (>= 12 chars, not a known weak default).
# This account is forced to change its password on first login.
DEFAULT_ADMIN_EMAIL=admin@yourcompany.com
DEFAULT_ADMIN_PASSWORD=
DEFAULT_ADMIN_NAME=Administrator

# ---- Optional vendor / developer super-admin (DISABLED by default) ---------
# Leave BOTH blank to disable. To enable, set both to non-empty values; the
# password must be strong (>= 12 chars). This account has full access and is
# protected from deletion/demotion by other admins.
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=
SUPER_ADMIN_NAME=Super Admin

# ---- Database --------------------------------------------------------------
# Default is a local SQLite file. (PostgreSQL not yet supported by the ORM
# layer — a postgres:// URL is automatically downgraded to SQLite.)
DATABASE_URL=sqlite:///./data/dogar_trading.db

# ---- Company branding ------------------------------------------------------
COMPANY_NAME=Dogar Trading Corporation
COMPANY_TAGLINE=Global Trading & Overseas Employment Solutions

# ---- CORS ------------------------------------------------------------------
# Comma-separated list of allowed browser origins. Empty = same-origin only.
# e.g. CORS_ORIGINS=https://portal.yourcompany.com,https://admin.yourcompany.com
CORS_ORIGINS=

# ---- Cookies ---------------------------------------------------------------
# Force Secure (HTTPS-only) cookies. Auto-enabled in production; set to
# false only for local HTTP development.
# COOKIE_SECURE=true

# ---- Feature flags (all OFF = production-safe) -----------------------------
# Seed fake demo clients/candidates/agents (NEVER enable in production).
SEED_DEMO_DATA=false
# Auto-restore a bundled SQL dump into an empty DB on boot (off by default).
AUTO_RESTORE_BUNDLED_SQL=false
# Return raw password-reset tokens in API responses (internal/dev only).
EXPOSE_RESET_TOKEN=false

# ---- Optional integrations -------------------------------------------------
# OpenAI (chatbot + passport OCR vision). Leave blank to disable those
# features — the app boots fine without them.
# OPENAI_API_KEY=
# OPENAI_BASE_URL=
